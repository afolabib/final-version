rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ── PRODUCTION NOTE ──────────────────────────────────────────────────────
    // Currently open for development. To lock down for production, replace
    // the wildcard rule below with the auth-scoped rules in firestore.rules.prod
    // After confirming all users authenticate via Firebase Auth (no guest mode).
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
